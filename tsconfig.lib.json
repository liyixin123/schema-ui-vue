{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./dist-lib/types",
    "noEmit": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/index.ts",
    "src/types/**/*.ts",
    "src/utils/**/*.ts",
    "src/composables/**/*.ts",
    "src/components/**/*.vue"
  ]
}
