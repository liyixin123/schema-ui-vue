{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "算法检测参数配置",
  "description": "尺寸测量与视觉检测算法的参数配置",
  "properties": {
    "length": {
      "type": "object",
      "title": "长度",
      "properties": {
        "detection": {
          "type": "object",
          "title": "检测参数",
          "x-column": "detection",
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "启用",
              "default": true
            },
            "roiX": {
              "type": "integer",
              "title": "ROI X",
              "minimum": 0,
              "default": 0
            },
            "roiY": {
              "type": "integer",
              "title": "ROI Y",
              "minimum": 0,
              "default": 0
            },
            "roiWidth": {
              "type": "integer",
              "title": "ROI 宽",
              "minimum": 1,
              "default": 640
            },
            "roiHeight": {
              "type": "integer",
              "title": "ROI 高",
              "minimum": 1,
              "default": 480
            },
            "advancedSettings": {
              "type": "object",
              "title": "高级设置",
              "properties": {
                "algorithm": {
                  "type": "string",
                  "title": "检测算法",
                  "enum": ["Canny", "Sobel", "Laplacian"],
                  "default": "Canny"
                },
                "threshold1": {
                  "type": "number",
                  "title": "阈值1",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 50
                },
                "threshold2": {
                  "type": "number",
                  "title": "阈值2",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 150
                }
              }
            }
          }
        },
        "quality": {
          "type": "object",
          "title": "质检参数",
          "x-column": "quality",
          "properties": {
            "nominalValue": {
              "type": "number",
              "title": "标称值 (mm)",
              "default": 100.0
            },
            "upperTolerance": {
              "type": "number",
              "title": "上偏差 (mm)",
              "default": 0.1
            },
            "lowerTolerance": {
              "type": "number",
              "title": "下偏差 (mm)",
              "default": -0.1
            },
            "unit": {
              "type": "string",
              "title": "单位",
              "enum": ["mm", "cm", "inch", "px"],
              "default": "mm"
            }
          }
        },
        "result": {
          "type": "object",
          "title": "结果显示",
          "x-column": "result",
          "x-readonly": true,
          "properties": {
            "measuredValue": {
              "type": "number",
              "title": "测量值 (mm)"
            },
            "deviation": {
              "type": "number",
              "title": "偏差 (mm)"
            },
            "verdict": {
              "type": "string",
              "title": "判定结果",
              "enum": ["合格", "不合格", "待检测"],
              "default": "待检测"
            }
          }
        }
      }
    },
    "width": {
      "type": "object",
      "title": "宽度",
      "properties": {
        "detection": {
          "type": "object",
          "title": "检测参数",
          "x-column": "detection",
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "启用",
              "default": true
            },
            "roiX": {
              "type": "integer",
              "title": "ROI X",
              "minimum": 0,
              "default": 0
            },
            "roiY": {
              "type": "integer",
              "title": "ROI Y",
              "minimum": 0,
              "default": 0
            },
            "roiWidth": {
              "type": "integer",
              "title": "ROI 宽",
              "minimum": 1,
              "default": 640
            },
            "roiHeight": {
              "type": "integer",
              "title": "ROI 高",
              "minimum": 1,
              "default": 480
            },
            "advancedSettings": {
              "type": "object",
              "title": "高级设置",
              "properties": {
                "algorithm": {
                  "type": "string",
                  "title": "检测算法",
                  "enum": ["Canny", "Sobel", "Laplacian"],
                  "default": "Canny"
                },
                "threshold1": {
                  "type": "number",
                  "title": "阈值1",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 50
                },
                "threshold2": {
                  "type": "number",
                  "title": "阈值2",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 150
                }
              }
            }
          }
        },
        "quality": {
          "type": "object",
          "title": "质检参数",
          "x-column": "quality",
          "properties": {
            "nominalValue": {
              "type": "number",
              "title": "标称值 (mm)",
              "default": 50.0
            },
            "upperTolerance": {
              "type": "number",
              "title": "上偏差 (mm)",
              "default": 0.05
            },
            "lowerTolerance": {
              "type": "number",
              "title": "下偏差 (mm)",
              "default": -0.05
            },
            "unit": {
              "type": "string",
              "title": "单位",
              "enum": ["mm", "cm", "inch", "px"],
              "default": "mm"
            }
          }
        },
        "result": {
          "type": "object",
          "title": "结果显示",
          "x-column": "result",
          "x-readonly": true,
          "properties": {
            "measuredValue": {
              "type": "number",
              "title": "测量值 (mm)"
            },
            "deviation": {
              "type": "number",
              "title": "偏差 (mm)"
            },
            "verdict": {
              "type": "string",
              "title": "判定结果",
              "enum": ["合格", "不合格", "待检测"],
              "default": "待检测"
            }
          }
        }
      }
    },
    "roundness": {
      "type": "object",
      "title": "圆度",
      "properties": {
        "detection": {
          "type": "object",
          "title": "检测参数",
          "x-column": "detection",
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "启用",
              "default": false
            },
            "minRadius": {
              "type": "number",
              "title": "最小半径 (px)",
              "minimum": 1,
              "default": 10
            },
            "maxRadius": {
              "type": "number",
              "title": "最大半径 (px)",
              "minimum": 1,
              "default": 200
            },
            "fitMethod": {
              "type": "string",
              "title": "拟合方法",
              "enum": ["最小二乘法", "最大内切圆", "最小外接圆"],
              "default": "最小二乘法"
            }
          }
        },
        "quality": {
          "type": "object",
          "title": "质检参数",
          "x-column": "quality",
          "properties": {
            "maxRoundnessError": {
              "type": "number",
              "title": "最大圆度误差 (mm)",
              "default": 0.02
            },
            "unit": {
              "type": "string",
              "title": "单位",
              "enum": ["mm", "μm"],
              "default": "mm"
            }
          }
        },
        "result": {
          "type": "object",
          "title": "结果显示",
          "x-column": "result",
          "x-readonly": true,
          "properties": {
            "roundnessError": {
              "type": "number",
              "title": "圆度误差 (mm)"
            },
            "centerX": {
              "type": "number",
              "title": "圆心 X (px)"
            },
            "centerY": {
              "type": "number",
              "title": "圆心 Y (px)"
            },
            "verdict": {
              "type": "string",
              "title": "判定结果",
              "enum": ["合格", "不合格", "待检测"],
              "default": "待检测"
            }
          }
        }
      }
    }
  }
}
