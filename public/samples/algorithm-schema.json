{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "算法检测参数配置",
  "description": "尺寸测量与视觉检测算法的参数配置",
  "properties": {
    "length": {
      "type": "object",
      "title": "长度",
      "properties": {
        "detection": {
          "type": "object",
          "title": "检测参数",
          "x-column": "detection",
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "启用",
              "default": true
            },
            "label": {
              "type": "string",
              "title": "字符串类型",
              "description": "自定义标签，用于标注该测量项",
              "default": "测量项A"
            },
            "paramNumber": {
              "type": "number",
              "title": "数字类型",
              "description": "范围0-5",
              "default": 1.0,
              "minimum": 0,
              "maximum": 5.0
            },
            "remark": {
              "type": "string",
              "title": "备注",
              "format": "textarea",
              "description": "详细备注，支持多行文本",
              "default": ""
            },
            "excludeAngles": {
              "type": "array",
              "title": "数组类型",
              "description": "可自由增删数字",
              "items": {
                "type": "number"
              },
              "default": []
            },
            "calibrationPath": {
              "type": "array",
              "title": "标定路点",
              "description": "在图像上绘制，相邻点依次连接形成标定折线",
              "x-canvas": {
                "type": "pathpoint",
                "group": "length_calibration"
              },
              "items": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              },
              "default": []
            },
            "detectionRoi": {
              "type": "array",
              "title": "检测区域",
              "description": "在图像上绘制 ROI 多边形，框定检测范围",
              "x-canvas": { "type": "roi", "group": "length_roi" },
              "items": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              },
              "default": []
            },
            "advancedSettings": {
              "type": "object",
              "title": "高级设置",
              "properties": {
                "algorithm": {
                  "type": "string",
                  "title": "检测算法",
                  "enum": ["Canny", "Sobel", "Laplacian"],
                  "default": "Canny"
                },
                "threshold1": {
                  "type": "number",
                  "title": "阈值1",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 50
                },
                "threshold2": {
                  "type": "number",
                  "title": "阈值2",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 150
                }
              }
            }
          }
        },
        "quality": {
          "type": "array",
          "title": "QA参数",
          "x-column": "quality",
          "items": {
            "type": "object",
            "title": "规则",
            "properties": {
              "nominalValue": {
                "type": "number",
                "title": "理论值",
                "default": 0
              },
              "upperLimit": {
                "type": "number",
                "title": "上限",
                "default": 0
              },
              "lowerLimit": {
                "type": "number",
                "title": "下限",
                "default": 0
              },
              "unit": {
                "type": "string",
                "title": "单位",
                "enum": ["mm", "cm", "inch", "px"],
                "default": "mm"
              }
            }
          },
          "default": [
            {
              "nominalValue": 100.0,
              "upperLimit": 100.1,
              "lowerLimit": 99.9,
              "unit": "mm"
            },
            {
              "nominalValue": 50.0,
              "upperLimit": 50.05,
              "lowerLimit": 49.95,
              "unit": "mm"
            }
          ]
        },
        "result": {
          "type": "object",
          "title": "结果显示",
          "x-column": "result",
          "x-readonly": true,
          "properties": {
            "measuredValue": {
              "type": "number",
              "title": "测量值 (mm)"
            },
            "deviation": {
              "type": "number",
              "title": "偏差 (mm)"
            },
            "verdict": {
              "type": "string",
              "title": "判定结果",
              "enum": ["合格", "不合格", "待检测"],
              "default": "待检测"
            }
          }
        }
      }
    },
    "width": {
      "type": "object",
      "title": "宽度",
      "properties": {
        "detection": {
          "type": "object",
          "title": "检测参数",
          "x-column": "detection",
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "启用",
              "default": true
            },
            "detectionRoi": {
              "type": "array",
              "title": "检测区域",
              "description": "在图像上绘制 ROI 多边形，框定宽度检测范围",
              "x-canvas": { "type": "roi", "group": "width_roi" },
              "items": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              },
              "default": []
            },
            "advancedSettings": {
              "type": "object",
              "title": "高级设置",
              "properties": {
                "algorithm": {
                  "type": "string",
                  "title": "检测算法",
                  "enum": ["Canny", "Sobel", "Laplacian"],
                  "default": "Canny"
                },
                "threshold1": {
                  "type": "number",
                  "title": "阈值1",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 50
                },
                "threshold2": {
                  "type": "number",
                  "title": "阈值2",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 150
                }
              }
            }
          }
        },
        "quality": {
          "type": "array",
          "title": "QA参数",
          "x-column": "quality",
          "items": {
            "type": "object",
            "title": "规则",
            "properties": {
              "nominalValue": {
                "type": "number",
                "title": "理论值",
                "default": 0
              },
              "upperLimit": {
                "type": "number",
                "title": "上限",
                "default": 0
              },
              "lowerLimit": {
                "type": "number",
                "title": "下限",
                "default": 0
              },
              "unit": {
                "type": "string",
                "title": "单位",
                "enum": ["mm", "cm", "inch", "px"],
                "default": "mm"
              }
            }
          },
          "default": [
            {
              "nominalValue": 50.0,
              "upperLimit": 50.05,
              "lowerLimit": 49.95,
              "unit": "mm"
            },
            {
              "nominalValue": 30.0,
              "upperLimit": 30.03,
              "lowerLimit": 29.97,
              "unit": "mm"
            }
          ]
        },
        "result": {
          "type": "object",
          "title": "结果显示",
          "x-column": "result",
          "x-readonly": true,
          "properties": {
            "measuredValue": {
              "type": "number",
              "title": "测量值 (mm)"
            },
            "deviation": {
              "type": "number",
              "title": "偏差 (mm)"
            },
            "verdict": {
              "type": "string",
              "title": "判定结果",
              "enum": ["合格", "不合格", "待检测"],
              "default": "待检测"
            }
          }
        }
      }
    }
  }
}
