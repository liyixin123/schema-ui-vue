{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "算法检测参数配置",
  "description": "尺寸测量与视觉检测算法的参数配置",
  "properties": {
    "length": {
      "type": "object",
      "title": "长度",
      "properties": {
        "detection": {
          "type": "object",
          "title": "检测参数",
          "x-column": "detection",
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "启用",
              "default": true
            },
            "label": {
              "type": "string",
              "title": "标签",
              "description": "自定义标签，用于标注该测量项",
              "default": "测量项A"
            },
            "remark": {
              "type": "string",
              "title": "备注",
              "format": "textarea",
              "description": "详细备注，支持多行文本",
              "default": ""
            },
            "excludeAngles": {
              "type": "array",
              "title": "排除角度",
              "description": "检测时需跳过的角度（°）",
              "items": {
                "type": "number"
              },
              "default": []
            },
            "calibrationPath": {
              "type": "array",
              "title": "标定路点",
              "description": "在图像上绘制，相邻点依次连接形成标定折线",
              "x-canvas": { "type": "pathpoint", "group": "length_calibration" },
              "items": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              },
              "default": []
            },
            "detectionRoi": {
              "type": "array",
              "title": "检测区域",
              "description": "在图像上绘制 ROI 多边形，框定检测范围",
              "x-canvas": { "type": "roi", "group": "length_roi" },
              "items": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              },
              "default": []
            },
            "advancedSettings": {
              "type": "object",
              "title": "高级设置",
              "properties": {
                "algorithm": {
                  "type": "string",
                  "title": "检测算法",
                  "enum": ["Canny", "Sobel", "Laplacian"],
                  "default": "Canny"
                },
                "threshold1": {
                  "type": "number",
                  "title": "阈值1",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 50
                },
                "threshold2": {
                  "type": "number",
                  "title": "阈值2",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 150
                }
              }
            }
          }
        },
        "quality": {
          "type": "object",
          "title": "质检参数",
          "x-column": "quality",
          "properties": {
            "nominalValue": {
              "type": "number",
              "title": "标称值 (mm)",
              "default": 100.0
            },
            "upperTolerance": {
              "type": "number",
              "title": "上偏差 (mm)",
              "default": 0.1
            },
            "lowerTolerance": {
              "type": "number",
              "title": "下偏差 (mm)",
              "default": -0.1
            },
            "unit": {
              "type": "string",
              "title": "单位",
              "enum": ["mm", "cm", "inch", "px"],
              "default": "mm"
            }
          }
        },
        "result": {
          "type": "object",
          "title": "结果显示",
          "x-column": "result",
          "x-readonly": true,
          "properties": {
            "measuredValue": {
              "type": "number",
              "title": "测量值 (mm)"
            },
            "deviation": {
              "type": "number",
              "title": "偏差 (mm)"
            },
            "verdict": {
              "type": "string",
              "title": "判定结果",
              "enum": ["合格", "不合格", "待检测"],
              "default": "待检测"
            }
          }
        }
      }
    },
    "width": {
      "type": "object",
      "title": "宽度",
      "properties": {
        "detection": {
          "type": "object",
          "title": "检测参数",
          "x-column": "detection",
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "启用",
              "default": true
            },
            "detectionRoi": {
              "type": "array",
              "title": "检测区域",
              "description": "在图像上绘制 ROI 多边形，框定宽度检测范围",
              "x-canvas": { "type": "roi", "group": "width_roi" },
              "items": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              },
              "default": []
            },
            "advancedSettings": {
              "type": "object",
              "title": "高级设置",
              "properties": {
                "algorithm": {
                  "type": "string",
                  "title": "检测算法",
                  "enum": ["Canny", "Sobel", "Laplacian"],
                  "default": "Canny"
                },
                "threshold1": {
                  "type": "number",
                  "title": "阈值1",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 50
                },
                "threshold2": {
                  "type": "number",
                  "title": "阈值2",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 150
                }
              }
            }
          }
        },
        "quality": {
          "type": "object",
          "title": "质检参数",
          "x-column": "quality",
          "properties": {
            "nominalValue": {
              "type": "number",
              "title": "标称值 (mm)",
              "default": 50.0
            },
            "upperTolerance": {
              "type": "number",
              "title": "上偏差 (mm)",
              "default": 0.05
            },
            "lowerTolerance": {
              "type": "number",
              "title": "下偏差 (mm)",
              "default": -0.05
            },
            "unit": {
              "type": "string",
              "title": "单位",
              "enum": ["mm", "cm", "inch", "px"],
              "default": "mm"
            }
          }
        },
        "result": {
          "type": "object",
          "title": "结果显示",
          "x-column": "result",
          "x-readonly": true,
          "properties": {
            "measuredValue": {
              "type": "number",
              "title": "测量值 (mm)"
            },
            "deviation": {
              "type": "number",
              "title": "偏差 (mm)"
            },
            "verdict": {
              "type": "string",
              "title": "判定结果",
              "enum": ["合格", "不合格", "待检测"],
              "default": "待检测"
            }
          }
        }
      }
    }
  }
}
