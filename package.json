{
  "name": "schema-ui-vue",
  "version": "0.1.0",
  "description": "JSON Schema driven form generator for Vue 3. Pass a schema, get a form.",
  "keywords": [
    "vue",
    "vue3",
    "form",
    "json-schema",
    "form-generator",
    "configuration"
  ],
  "author": "your-name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liyixin123/schema-ui-vue.git"
  },
  "homepage": "https://github.com/liyixin123/schema-ui-vue#readme",
  "bugs": {
    "url": "https://github.com/liyixin123/schema-ui-vue/issues"
  },
  "type": "module",
  "main": "./dist-lib/schema-ui-vue.cjs",
  "module": "./dist-lib/schema-ui-vue.mjs",
  "types": "./dist-lib/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist-lib/schema-ui-vue.mjs",
      "require": "./dist-lib/schema-ui-vue.cjs",
      "types": "./dist-lib/types/index.d.ts"
    },
    "./style.css": "./dist-lib/style.css"
  },
  "files": [
    "dist-lib"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts && vue-tsc -p tsconfig.lib.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.5"
  }
}
